<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:paddingHorizontal="@dimen/screen_padding"
    android:paddingTop="@dimen/title_margin_top">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_dark"
            android:contentDescription="@string/main_search" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text_TitleScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_12"
            android:text="@string/main_search" />
    </LinearLayout>

    <!-- Search field -->
    <LinearLayout
        android:id="@+id/searchField"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="@dimen/margin_24"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_field"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Search icon -->
        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            app:tint="@color/search_icon_tint" />

        <!-- Input -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/search_hint"
            android:maxLines="1"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:textColor="@color/search_text"
            android:textColorHint="@color/search_hint_color" />

        <!-- Clear button -->
        <ImageView
            android:id="@+id/ivClear"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_clear"
            app:tint="@color/search_icon_tint"
            android:contentDescription="@string/clear_search"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
