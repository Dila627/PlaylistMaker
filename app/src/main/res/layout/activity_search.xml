<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSearch"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:paddingHorizontal="@dimen/screen_padding"
    android:paddingTop="@dimen/title_margin_top">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/main_search"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_dark" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text_TitleScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_12"
            android:text="@string/main_search" />
    </LinearLayout>

    <!-- Search field -->
    <FrameLayout
        android:id="@+id/searchField"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="@dimen/margin_24"
        android:background="@drawable/bg_search_field">

        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_search"
            app:tint="@color/search_hint_and_icons" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="@string/search_hint"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:textColor="@color/search_input_text"
            android:textColorHint="@color/search_hint_and_icons"
            android:textCursorDrawable="@drawable/cursor_search" />

        <ImageView
            android:id="@+id/ivClear"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/clear_search"
            android:src="@drawable/ic_clear"
            android:visibility="gone"
            app:tint="@color/search_hint_and_icons" />

    </FrameLayout>


    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_16"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTracks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/margin_16" />

        <!-- Placeholder (Empty / Error) -->
    <LinearLayout
        android:id="@+id/placeholderContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingHorizontal="@dimen/screen_padding">

        <ImageView
            android:id="@+id/placeholderImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/placeholderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_24"
            android:text="@string/nothing_found_title"
            android:textColor="@color/text_primary_search"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/placeholderText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:gravity="center"
            android:text="@string/connection_error_text"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_24"
            android:text="@string/retry"
            android:textColor="@color/retry_button_text"
            android:background="@drawable/bg_retry_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:textAllCaps="false"
            android:visibility="gone"/>

</LinearLayout>

    </FrameLayout>

</LinearLayout>
